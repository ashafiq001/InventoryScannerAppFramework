<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Mavis Inventory Scanner - Appium Test Suite" verbose="1">

    <!-- Sanity Tests - Quick app launch verification -->
    <test name="Sanity Tests">
        <classes>
            <class name="com.mavis.scanner.sanity.AppLaunchSanityTest"/>
        </classes>
    </test>

    <!-- Login Tests - Authentication and validation -->
    <test name="Login Tests">
        <classes>
            <class name="com.mavis.scanner.functional.LoginTest"/>
        </classes>
    </test>

    <!-- Tire Scanning Tests - Core scanning workflow -->
    <test name="Tire Scanning Tests">
        <classes>
            <class name="com.mavis.scanner.functional.TireScanningTest"/>
        </classes>
    </test>

    <!-- Parts Scanning Tests - Category-based workflow -->
    <test name="Parts Scanning Tests">
        <classes>
            <class name="com.mavis.scanner.functional.PartsScanningTest"/>
        </classes>
    </test>

    <!-- End-to-End Tests - Full inventory lifecycle -->
    <test name="End-to-End Tests">
        <classes>
            <class name="com.mavis.scanner.functional.InventoryEndToEndTest"/>
        </classes>
    </test>

</suite>
